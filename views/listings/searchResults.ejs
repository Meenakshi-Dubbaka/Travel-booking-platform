<%layout("/layouts/boilerplate")%>

<div class="container mt-2">
  <h4 class="mb-4">Search Results for "<%= query %>"</h4>

  <% if (results.length === 0) { %>
    <div class="alert alert-warning">
      No listings found. Try searching something else.
    </div>
  <% } else { %>
    <div class="row">
      <% results.forEach(listing => { %>
        <div class="col-md-4 mb-4">
          <div class="card shadow-sm h-100 ">
            <img src="<%= listing.image.url %>" class="card-img-top-rounded" alt="<%= listing.title %>" style="height: 16rem; object-fit: cover;">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= listing.title %></h5>
              <p class="card-text text-muted mb-2"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></p>
              <p class=>₹<%= listing.price %></p>
              <a href="/listings/<%= listing._id %>" class="btn btn-primary add-btn  mt-auto">View Details</a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>


